generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships    Membership[]
  sessions       Session[]
  accounts       Account[]
  createdInvites Invite[]
  createdLicitacoes        Licitacao[]
  createdEditais           Edital[]
  createdDocuments         Document[]
  createdDocumentAnalyses  DocumentAnalysis[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  companies     Company[]
  invites       Invite[]
  documentChats DocumentChat[]
}

model Company {
  id                      String   @id @default(cuid())
  cnpj                    String   @unique
  razao_social            String
  nome_fantasia           String?
  situacao_cadastral      String?
  data_situacao_cadastral String?
  data_abertura           String?
  porte                   String?
  natureza_juridica       String?
  cnae_fiscal             Int?
  cnae_fiscal_descricao   String?
  cnaes_secundarios       Json?
  logradouro              String?
  numero                  String?
  complemento             String?
  bairro                  String?
  municipio               String?
  uf                      String?
  cep                     String?
  telefone_1              String?
  email_empresa           String?
  capital_social          Float?
  opcao_pelo_simples      Boolean?
  opcao_pelo_mei          Boolean?
  organizationId          String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyMemberships CompanyMembership[]
  invites            Invite[]
  licitacoes         Licitacao[]
  editais            Edital[]
  documents          Document[]
  documentAnalyses   DocumentAnalysis[]
}

// ─── Membership ───────────────────────────────────────────────────────────────

model Membership {
  id             String           @id @default(cuid())
  role           OrganizationRole @default(MEMBER)
  userId         String
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyMemberships CompanyMembership[]

  @@unique([userId, organizationId])
}

/// Vínculo opcional entre um membro e empresas específicas da organização.
/// Se não houver registros, o acesso às empresas é definido pela lógica de negócio.
model CompanyMembership {
  id           String   @id @default(cuid())
  membershipId String
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([membershipId, companyId])
}

// ─── Invite ───────────────────────────────────────────────────────────────────

model Invite {
  id             String           @id @default(cuid())
  token          String           @unique
  email          String
  role           OrganizationRole
  organizationId String
  companyId      String
  createdById    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ─── Licitação ────────────────────────────────────────────────────────────────

model Licitacao {
  id                   String          @id @default(cuid())
  companyId            String
  createdById          String?
  status               LicitacaoStatus @default(IN_PROGRESS)
  metadados            Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  edital     Edital?

  @@index([companyId, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model Edital {
  id                     String       @id @default(cuid())
  licitacaoId            String       @unique
  companyId              String
  createdById            String?
  status                 EditalStatus @default(IN_PROGRESS)
  orgaoCnpj              String?
  orgaoRazaoSocial       String?
  orgaoEsfera            String?
  orgaoPoder             String?
  unidadeCodigo          String?
  unidadeNome            String?
  municipio              String?
  uf                     String?
  numero                 String?
  processo               String?
  modalidade             String?
  tipoInstrumento        String?
  modoDisputa            String?
  amparoLegal            String?
  srp                    Boolean      @default(false)
  objeto                 String?
  informacaoComplementar String?
  dataAbertura           DateTime?
  dataEncerramento       DateTime?
  valorEstimado          Decimal?     @db.Decimal(15, 2)
  dadosExtraidos         Json?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  licitacao  Licitacao  @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy  User?      @relation(fields: [createdById], references: [id], onDelete: SetNull)
  documents  Document[]

  @@index([companyId, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model Document {
  id                   String         @id @default(cuid())
  companyId            String
  editalId             String?
  createdById          String?
  type                 DocumentType   @default(EDITAL)
  originalName         String
  mimeType             String
  sizeBytes            Int
  storageProvider      String         @default("cloudflare_r2")
  storageBucket        String
  storageKey           String         @unique
  storageUrl           String
  vectorDocumentId     String         @unique
  vectorCollectionName String
  status               DocumentStatus @default(PROCESSING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  company    Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  edital     Edital?            @relation(fields: [editalId], references: [id], onDelete: SetNull)
  createdBy  User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  analyses   DocumentAnalysis[]
  chat       DocumentChat?

  @@index([companyId, createdAt])
  @@index([editalId, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}

model DocumentAnalysis {
  id              String                 @id @default(cuid())
  documentId      String
  companyId       String
  createdById     String?
  type            DocumentAnalysisType
  status          DocumentAnalysisStatus @default(PENDING)
  markdownContent String?
  result          Json?
  metrics         Json?
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([documentId, type, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model DocumentChat {
  id             String   @id @default(cuid())
  documentId     String   @unique
  organizationId String
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  document     Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([organizationId, createdAt])
}

model ChatMessage {
  id        String          @id @default(cuid())
  chatId    String
  role      ChatMessageRole
  content   String
  metadata  Json?
  createdAt DateTime        @default(now())

  chat    DocumentChat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sources ChatMessageSource[]

  @@index([chatId, createdAt])
}

model ChatMessageSource {
  id        String   @id @default(cuid())
  messageId String
  chunkId   String
  page      Int?
  score     Float
  snippet   String
  heading   String?
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([chunkId, createdAt])
}
// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum DocumentType {
  EDITAL
  ANEXO
  OUTRO
}

enum LicitacaoStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EditalStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentAnalysisType {
  EXTRACT_EDITAL
  SUMMARY
}

enum DocumentAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}
