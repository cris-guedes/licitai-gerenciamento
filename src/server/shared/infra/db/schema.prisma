  PNCP
  COMPRAS_GOV
  PORTAL_EXTERNO
  MANUAL
}

enum LicitacaoStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EditalStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentAnalysisType {
  EXTRACT_EDITAL
  SUMMARY
}

enum DocumentAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum EditalTipoVersao {
