generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String?
  name          String
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships              Membership[]
  sessions                 Session[]
  accounts                 Account[]
  createdInvites           Invite[]
  createdLicitacoes        Licitacao[]
  createdEditais           Edital[]
  createdDocuments         Document[]
  createdDocumentAnalyses  DocumentAnalysis[]
  createdEditalAnalyses    EditalAnalysis[]
  responsibleOportunidades Oportunidade[]     @relation("OportunidadeResponsavel")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Tenant ───────────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   Membership[]
  companies     Company[]
  invites       Invite[]
  documentChats DocumentChat[]
}

model Company {
  id                      String   @id @default(cuid())
  cnpj                    String   @unique
  razao_social            String
  nome_fantasia           String?
  situacao_cadastral      String?
  data_situacao_cadastral String?
  data_abertura           String?
  porte                   String?
  natureza_juridica       String?
  cnae_fiscal             Int?
  cnae_fiscal_descricao   String?
  cnaes_secundarios       Json?
  logradouro              String?
  numero                  String?
  complemento             String?
  bairro                  String?
  municipio               String?
  uf                      String?
  cep                     String?
  telefone_1              String?
  email_empresa           String?
  capital_social          Float?
  opcao_pelo_simples      Boolean?
  opcao_pelo_mei          Boolean?
  organizationId          String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyMemberships CompanyMembership[]
  invites            Invite[]
  licitacoes         Licitacao[]
  editais            Edital[]
  documents          Document[]
  documentAnalyses   DocumentAnalysis[]
  editalAnalyses     EditalAnalysis[]
  oportunidades      Oportunidade[]
}

// ─── Membership ───────────────────────────────────────────────────────────────

model Membership {
  id             String           @id @default(cuid())
  role           OrganizationRole @default(MEMBER)
  userId         String
  organizationId String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  companyMemberships CompanyMembership[]

  @@unique([userId, organizationId])
}

/// Vínculo opcional entre um membro e empresas específicas da organização.
/// Se não houver registros, o acesso às empresas é definido pela lógica de negócio.
model CompanyMembership {
  id           String   @id @default(cuid())
  membershipId String
  companyId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([membershipId, companyId])
}

// ─── Invite ───────────────────────────────────────────────────────────────────

model Invite {
  id             String           @id @default(cuid())
  token          String           @unique
  email          String
  role           OrganizationRole
  organizationId String
  companyId      String
  createdById    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
}

// ─── Licitação ────────────────────────────────────────────────────────────────

model Licitacao {
  id                       String                 @id @default(cuid())
  companyId                String
  createdById              String?
  status                   LicitacaoStatus        @default(IN_PROGRESS)
  metadados                Json?
  sourceSystem             LicitacaoSourceSystem?
  sourceReference          String?
  numeroControlePncp       String?                @unique
  anoCompra                Int?
  sequencialCompra         Int?
  numeroLicitacao          String?
  processoAdministrativo   String?
  modalidadeNome           String?
  tipoInstrumentoNome      String?
  objetoResumo             String?
  situacaoOficial          String?
  valorEstimadoTotal       Decimal?               @db.Decimal(15, 2)
  valorHomologadoTotal     Decimal?               @db.Decimal(15, 2)
  dataPublicacao           DateTime?
  dataAberturaProposta     DateTime?
  dataEncerramentoProposta DateTime?
  linkSistemaOrigem        String?
  linkProcessoEletronico   String?
  ultimaAtualizacaoOficial DateTime?
  orgaoGerenciadorId       String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  orgaoGerenciador OrgaoPublico?  @relation(fields: [orgaoGerenciadorId], references: [id], onDelete: SetNull)
  edital           Edital?
  oportunidades    Oportunidade[]

  @@index([companyId, createdAt])
  @@index([createdById, createdAt])
  @@index([orgaoGerenciadorId, createdAt])
  @@index([status, createdAt])
}

model Edital {
  id                     String           @id @default(cuid())
  licitacaoId            String           @unique
  companyId              String
  createdById            String?
  status                 EditalStatus     @default(IN_PROGRESS)
  versao                 Int              @default(1)
  isAtual                Boolean          @default(true)
  tipoVersao             EditalTipoVersao @default(ORIGINAL)
  documentoPrincipalId   String?
  orgaoCnpj              String?
  orgaoRazaoSocial       String?
  orgaoEsfera            String?
  orgaoPoder             String?
  unidadeCodigo          String?
  unidadeNome            String?
  municipio              String?
  uf                     String?
  numero                 String?
  processo               String?
  modalidade             String?
  tipoInstrumento        String?
  modoDisputa            String?
  amparoLegal            String?
  srp                    Boolean          @default(false)
  objeto                 String?
  informacaoComplementar String?
  dataAbertura           DateTime?
  dataEncerramento       DateTime?
  valorEstimado          Decimal?         @db.Decimal(15, 2)
  dadosExtraidos         Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  licitacao          Licitacao                    @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
  company            Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy          User?                        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  documentoPrincipal Document?                    @relation("EditalDocumentoPrincipal", fields: [documentoPrincipalId], references: [id], onDelete: SetNull)
  documents          Document[]                   @relation("EditalDocumentos")
  cronograma         EditalCronograma?
  certame            EditalCertame?
  itensDetalhados    EditalItem[]
  orgaos             EditalOrgao[]
  habilitacoes       EditalHabilitacaoExigencia[]
  analyses           EditalAnalysis[]
  oportunidades      Oportunidade[]

  @@index([companyId, createdAt])
  @@index([createdById, createdAt])
  @@index([documentoPrincipalId])
  @@index([status, createdAt])
}

model Document {
  id                   String         @id @default(cuid())
  companyId            String
  editalId             String?
  createdById          String?
  type                 DocumentType   @default(EDITAL)
  originalName         String
  mimeType             String
  sizeBytes            Int
  storageProvider      String         @default("cloudflare_r2")
  storageBucket        String
  storageKey           String         @unique
  storageUrl           String
  vectorDocumentId     String         @unique
  vectorCollectionName String
  status               DocumentStatus @default(PROCESSING)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  edital               Edital?            @relation("EditalDocumentos", fields: [editalId], references: [id], onDelete: SetNull)
  createdBy            User?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  analyses             DocumentAnalysis[]
  chat                 DocumentChat?
  documentoPrincipalDe Edital[]           @relation("EditalDocumentoPrincipal")

  @@index([companyId, createdAt])
  @@index([editalId, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}

model DocumentAnalysis {
  id              String                 @id @default(cuid())
  documentId      String
  companyId       String
  createdById     String?
  type            DocumentAnalysisType
  status          DocumentAnalysisStatus @default(PENDING)
  markdownContent String?
  result          Json?
  metrics         Json?
  errorMessage    String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([documentId, type, createdAt])
  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model EditalAnalysis {
  id           String               @id @default(cuid())
  editalId     String
  companyId    String
  createdById  String?
  type         EditalAnalysisType
  status       EditalAnalysisStatus @default(PENDING)
  result       Json?
  metrics      Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  edital    Edital  @relation(fields: [editalId], references: [id], onDelete: Cascade)
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([createdById, createdAt])
  @@index([editalId, type, createdAt])
  @@index([status, createdAt])
}

model Oportunidade {
    id                String             @id @default(cuid())
    companyId         String
    licitacaoId       String?
    editalId          String?
  responsavelUserId String?
  status            OportunidadeStatus @default(DRAFT)
  metadata          Json?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

    company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
    licitacao   Licitacao?         @relation(fields: [licitacaoId], references: [id], onDelete: Cascade)
    edital      Edital?            @relation(fields: [editalId], references: [id], onDelete: Cascade)
  responsavel User?              @relation("OportunidadeResponsavel", fields: [responsavelUserId], references: [id], onDelete: SetNull)
  itens       OportunidadeItem[]

  @@unique([companyId, licitacaoId])
  @@index([companyId, createdAt])
  @@index([licitacaoId, createdAt])
  @@index([editalId, createdAt])
  @@index([responsavelUserId, createdAt])
  @@index([status, createdAt])
}

model OportunidadeItem {
  id             String   @id @default(cuid())
  oportunidadeId String
  editalItemId   String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  oportunidade Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)
  editalItem   EditalItem   @relation(fields: [editalItemId], references: [id], onDelete: Cascade)

  @@unique([oportunidadeId, editalItemId])
  @@index([oportunidadeId, createdAt])
  @@index([editalItemId, createdAt])
}

model OrgaoPublico {
  id            String       @id @default(cuid())
  cnpj          String?
  razaoSocial   String?
  codigoUnidade String?
  nomeUnidade   String?
  municipio     String?
  uf            String?
  esfera        OrgaoEsfera?
  poder         OrgaoPoder?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  licitacoesGerenciadas Licitacao[]
  editalOrgaos          EditalOrgao[]

  @@index([cnpj])
  @@index([codigoUnidade])
}

model EditalCronograma {
  editalId           String    @id
  acolhimentoInicio  DateTime?
  acolhimentoFim     DateTime?
  horaLimite         String?
  sessaoPublicaEm    DateTime?
  esclarecimentosAte DateTime?
  impugnacaoAte      DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  edital Edital @relation(fields: [editalId], references: [id], onDelete: Cascade)
}

model EditalCertame {
  editalId             String   @id
  modoDisputa          String?
  criterioJulgamento   String?
  tipoLance            String?
  intervaloLances      String?
  duracaoSessaoMinutos Int?
  exclusivoMeEpp       Boolean?
  permiteConsorcio     Boolean?
  exigeVisitaTecnica   Boolean?
  permiteAdesao        Boolean?
  percentualAdesao     Decimal? @db.Decimal(8, 2)
  regionalidade        String?
  difal                Boolean?
  vigenciaAtaMeses     Int?
  vigenciaContratoDias Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  edital Edital @relation(fields: [editalId], references: [id], onDelete: Cascade)
}

model EditalItem {
  id                     String          @id @default(cuid())
  editalId               String
  numeroItem             Int?
  descricao              String?
  tipoItem               EditalItemTipo?
  lote                   String?
  quantidadeTotal        Decimal?        @db.Decimal(18, 4)
  unidadeMedida          String?
  valorUnitarioEstimado  Decimal?        @db.Decimal(15, 2)
  valorTotalEstimado     Decimal?        @db.Decimal(15, 2)
  codigoCatmatCatser     String?
  codigoNcmNbs           String?
  criterioJulgamentoItem String?
  beneficioTributario    String?
  observacao             String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  edital                Edital             @relation(fields: [editalId], references: [id], onDelete: Cascade)
  distribuicoesPorOrgao EditalOrgaoItem[]
  oportunidadeItens     OportunidadeItem[]

  @@index([editalId, createdAt])
  @@index([editalId, numeroItem])
}

model EditalOrgao {
  id        String           @id @default(cuid())
  editalId  String
  orgaoId   String
  papel     EditalOrgaoPapel
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  edital Edital            @relation(fields: [editalId], references: [id], onDelete: Cascade)
  orgao  OrgaoPublico      @relation(fields: [orgaoId], references: [id], onDelete: Cascade)
  itens  EditalOrgaoItem[]

  @@unique([editalId, orgaoId, papel])
  @@index([editalId, createdAt])
  @@index([orgaoId, createdAt])
}

model EditalOrgaoItem {
  id                   String   @id @default(cuid())
  editalOrgaoId        String
  editalItemId         String
  quantidadeSolicitada Decimal? @db.Decimal(18, 4)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  editalOrgao EditalOrgao @relation(fields: [editalOrgaoId], references: [id], onDelete: Cascade)
  editalItem  EditalItem  @relation(fields: [editalItemId], references: [id], onDelete: Cascade)

  @@unique([editalOrgaoId, editalItemId])
  @@index([editalOrgaoId, createdAt])
  @@index([editalItemId, createdAt])
}

model EditalHabilitacaoExigencia {
  id          String   @id @default(cuid())
  editalId    String
  tipo        String
  categoria   String
  obrigatorio Boolean  @default(true)
  ordem       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  edital Edital @relation(fields: [editalId], references: [id], onDelete: Cascade)

  @@index([editalId, createdAt])
  @@index([editalId, ordem])
}

model DocumentChat {
  id             String   @id @default(cuid())
  documentId     String   @unique
  organizationId String
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]

  @@index([organizationId, createdAt])
}

model ChatMessage {
  id        String          @id @default(cuid())
  chatId    String
  role      ChatMessageRole
  content   String
  metadata  Json?
  createdAt DateTime        @default(now())

  chat    DocumentChat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sources ChatMessageSource[]

  @@index([chatId, createdAt])
}

model ChatMessageSource {
  id        String   @id @default(cuid())
  messageId String
  chunkId   String
  page      Int?
  score     Float
  snippet   String
  heading   String?
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, createdAt])
  @@index([chunkId, createdAt])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum DocumentType {
  EDITAL
  ANEXO
  OUTRO
}

enum LicitacaoSourceSystem {
  PNCP
  COMPRAS_GOV
  PORTAL_EXTERNO
  MANUAL
}

enum LicitacaoStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum EditalStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DocumentAnalysisType {
  EXTRACT_EDITAL
  SUMMARY
}

enum DocumentAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum EditalTipoVersao {
  ORIGINAL
  RETIFICACAO
  ADENDO
  CONSOLIDADO
}

enum EditalItemTipo {
  MATERIAL
  SERVICO
}

enum EditalOrgaoPapel {
  GERENCIADOR
  PARTICIPANTE
}

enum OrgaoEsfera {
  FEDERAL
  ESTADUAL
  MUNICIPAL
}

enum OrgaoPoder {
  EXECUTIVO
  LEGISLATIVO
  JUDICIARIO
}

enum EditalAnalysisType {
  EXTRACT_CADASTRO
  SUMMARY_GERAL
}

enum EditalAnalysisStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum OportunidadeStatus {
  DRAFT
  ACTIVE
  CANCELLED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}
