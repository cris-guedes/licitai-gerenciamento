{
  "name": "licitai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && next start",
    "lint": "eslint",
    "generate:spec": "npx tsx --tsconfig tsconfig.json scripts/generate-openapi-spec.ts",
    "generate:client": "npm run generate:spec && openapi --input openapi.generated.json --output src/client/main/infra/apis/api-core --client axios --name CoreApiClient --useOptions --useUnionTypes --indent 2",
    "generate:document-handler": "openapi --input src/server/shared/lib/docs/api.document-handler.json --output src/server/shared/lib/document-handler/generated --client fetch --useOptions --useUnionTypes --indent 2",
    "generate:pncp": "openapi --input src/server/shared/lib/docs/pncp-api.json --output src/server/shared/lib/pncp --client fetch --useOptions --useUnionTypes --indent 2 && node -e \"const fs=require('fs'),f='src/server/shared/lib/pncp/core/OpenAPI.ts';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(\\\"BASE: '/api/pncp'\\\",\\\"BASE: 'https://pncp.gov.br/api/pncp'\\\"))\"",
    "generate:pncp-consulta": "openapi --input src/server/shared/lib/docs/pncp-consultas.json --output src/server/shared/lib/pncp-consultas --client fetch --name PncpPortalClient --useOptions --useUnionTypes --indent 2 && node -e \"const fs=require('fs'),f='src/server/shared/lib/pncp-consultas/PncpPortalClient.ts';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(\\\"BASE: config?.BASE ?? '/api/consulta'\\\",\\\"BASE: config?.BASE ?? 'https://pncp.gov.br/api/consulta'\\\"))\"",
    "generate:pncp-historico": "openapi --input src/server/shared/lib/docs/api.pncp.historico.yml --output src/server/shared/lib/pncp-historico --client fetch --useOptions --useUnionTypes --indent 2 && node -e \"const fs=require('fs'),f='src/server/shared/lib/pncp-historico/core/OpenAPI.ts';fs.writeFileSync(f,fs.readFileSync(f,'utf8').replace(\\\"BASE: 'https://pncp.gov.br/api/pncp'\\\",\\\"BASE: 'https://pncp.gov.br/api/pncp'\\\"))\""
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "@contentsquare/tag-sdk": "^1.1.0",
    "@dqbd/tiktoken": "^1.0.22",
    "@hookform/resolvers": "^5.2.2",
    "@langchain/core": "^1.1.39",
    "@langchain/textsplitters": "^1.0.1",
    "@opendocsg/pdf2md": "^0.2.6",
    "@orama/orama": "^3.1.18",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@types/bcryptjs": "^2.4.6",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.158",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "fastify": "^5.7.4",
    "fuse.js": "^7.1.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "openapi-typescript-codegen": "^0.30.0",
    "p-queue": "^9.1.2",
    "pdfreader": "^3.0.8",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4",
    "recharts": "2.15.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vaul": "^1.1.2",
    "wink-eng-lite-web-model": "^1.8.1",
    "wink-nlp": "^2.4.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/unist": "^3.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.5.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
